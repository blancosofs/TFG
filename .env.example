APP_NAME=Edunoly
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://edunoly.com

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Para la base de datos
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=edunoly
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
CACHE_STORE=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

# ── CONFIGURACIÓN DE CORREO ──

MAIL_MAILER=smtp
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@edunoly.com"
MAIL_FROM_NAME="Edunoly Admin"

