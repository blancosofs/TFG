# ── CONFIGURACIÓN GENERAL ──
APP_NAME=Edunoly
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

LOG_CHANNEL=stack
LOG_LEVEL=debug

SESSION_DRIVER=file
CACHE_STORE=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

# ── CONFIGURACIÓN BASE DE DATOS (DOCKER / SAIL LOCAL) ──
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=edunoly
DB_USERNAME=sail
DB_PASSWORD=password

# ── PUERTOS REDIRECCIÓN HOST ──
FORWARD_DB_PORT=3309
APP_PORT=8080

# ── CONFIGURACIÓN DE CORREO LOCAL (MAILPIT) ──
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@edunoly.com"
MAIL_FROM_NAME="Edunoly Admin"